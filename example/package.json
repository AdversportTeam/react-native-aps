{
  "name": "react-native-aps-example",
  "description": "Example app for react-native-aps",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "postinstall": "find node_modules/react-native -name '*.podspec' -o -name '*.rb' | xargs grep -l '11\\.0\\.2' 2>/dev/null | xargs sed -i '' 's/11\\.0\\.2/12.1.0/g' 2>/dev/null || true"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-native": "0.77.3",
    "react-native-aps": "link:../",
    "react-native-google-mobile-ads": "^14.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "15.0.1",
    "@react-native-community/cli-platform-android": "15.0.1",
    "@react-native-community/cli-platform-ios": "15.0.1",
    "@react-native/babel-preset": "0.77.3",
    "@react-native/metro-config": "0.77.3",
    "@types/react": "^18.2.6",
    "babel-plugin-module-resolver": "^4.1.0",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
